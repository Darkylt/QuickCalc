{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "quick-calc",
  "version": "0.1.0",
  "identifier": "com.darkylmusic.quick-calc",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "QuickCalc",
        "width": 400,
        "height": 180,
        "minWidth": 400,
        "minHeight": 180,
        "alwaysOnTop": true,
        "visible": true,
        "decorations": false
      }
    ],
    
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
